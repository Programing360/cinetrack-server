{
  "info": {
    "_postman_id": "62ea5ca9-05a7-47a1-a66a-989516dd3acd",
    "name": "Cemzo Full Stack Assignment API",
    "description": "CineTrack REST API Documentation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    {
      "key": "baseUrl",
      "value": "https://your-render-api.onrender.com"
    },
    {
      "key": "movieId",
      "value": "PUT_MOVIE_ID_HERE"
    }
  ],

  "item": [
    {
      "name": "Get All Movies",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/movies",
          "host": ["{{baseUrl}}"],
          "path": ["movies"]
        }
      }
    },

    {
      "name": "Add Movie",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Avatar\",\n  \"genre\": \"Adventure\",\n  \"releaseYear\": 2022,\n  \"posterUrl\": \"https://example.com/avatar.jpg\",\n  \"rating\": 4.8,\n  \"isWatched\": false,\n  \"review\": \"\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/movies",
          "host": ["{{baseUrl}}"],
          "path": ["movies"]
        }
      }
    },

    {
      "name": "Update Movie (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Avatar Updated\",\n  \"rating\": 5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/movies/{{movieId}}",
          "host": ["{{baseUrl}}"],
          "path": ["movies", "{{movieId}}"]
        }
      }
    },

    {
      "name": "Delete Movie",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/movies/{{movieId}}",
          "host": ["{{baseUrl}}"],
          "path": ["movies", "{{movieId}}"]
        }
      }
    }
  ]
}